# Editor / IDE state
.idea/
.vscode/
*.swp
*~

# Local tooling state (Claude Code, etc.)
.claude/

# Build outputs
bin/
tmp/
out/
coverage/

# Test artifacts that occasionally land in the workspace
*.cov
*.log
*.out
*.bak
.DS_Store

# Generated by `templ generate` at build time inside the Docker image.
# Source of truth lives in *.templ files; the *_templ.go files are produced
# by Dockerfile, Dockerfile.test, and tests/entrypoint.sh on every build.
*_templ.go
*_templ_*.go
